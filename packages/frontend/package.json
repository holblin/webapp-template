{
  "name": "webapp-template-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "author": "Jean-Philippe Zolesio",
  "engines": {
    "node": ">=24.11.0"
  },
  "scripts": {
    "routes:generate": "tsr generate",
    "dev": "concurrently -k -n tsr,vite \"tsr watch\" \"vite\"",
    "dev:e2e": "npm run routes:generate && vite --host 127.0.0.1 --port 4080",
    "build": "npm run routes:generate && tsc -b && vite build",
    "typecheck": "npm run routes:generate && tsc -p tsconfig.app.json --noEmit",
    "test:unit": "npm run routes:generate && vitest run --config vitest.config.ts",
    "test:unit:watch": "npm run routes:generate && vitest --config vitest.config.ts",
    "test:unit:coverage": "npm run routes:generate && vitest run --config vitest.config.ts --coverage",
    "test:storybook": "npm run routes:generate && vitest run --config vitest.storybook.workspace.ts --project \"storybook*\"",
    "test:storybook:watch": "npm run routes:generate && vitest --config vitest.storybook.workspace.ts --project \"storybook*\"",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "STORYBOOK_BASE_PATH=/storybook/ storybook build --output-dir dist-storybook"
  },
  "dependencies": {
    "@apollo/client": "^4.1.9",
    "@react-aria/optimize-locales-plugin": "^1.2.0",
    "@react-spectrum/s2": "^1.3.0",
    "@tanstack/react-router": "^1.169.1",
    "@xyflow/react": "^12.10.2",
    "graphql": "^16.13.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "unplugin-parcel-macros": "^0.2.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.2",
    "@storybook/addon-a11y": "^10.3.0",
    "@storybook/addon-docs": "^10.3.0",
    "@storybook/addon-vitest": "^10.3.0",
    "@storybook/react-vite": "^10.3.0",
    "@tanstack/router-cli": "^1.166.14",
    "@tanstack/router-plugin": "^1.166.14",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.0",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "lightningcss": "^1.32.0",
    "playwright": "^1.58.2",
    "storybook": "^10.3.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
