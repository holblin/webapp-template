{
  "name": "webapp-template-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "author": "Jean-Philippe Zolesio",
  "engines": {
    "node": ">=24.11.0"
  },
  "scripts": {
    "routes:generate": "tsr generate",
    "dev": "concurrently -k -n tsr,vite \"tsr watch\" \"vite\"",
    "dev:e2e": "npm run routes:generate && vite --host 127.0.0.1 --port 4080",
    "build": "npm run routes:generate && tsc -b && vite build",
    "typecheck": "npm run routes:generate && tsc -p tsconfig.app.json --noEmit",
    "test:unit": "npm run routes:generate && vitest run --config vitest.config.ts",
    "test:unit:watch": "npm run routes:generate && vitest --config vitest.config.ts",
    "test:unit:coverage": "npm run routes:generate && vitest run --config vitest.config.ts --coverage",
    "test:storybook": "npm run routes:generate && vitest run --workspace vitest.storybook.workspace.ts --project \"storybook*\"",
    "test:storybook:watch": "npm run routes:generate && vitest --workspace vitest.storybook.workspace.ts --project \"storybook*\"",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@react-aria/optimize-locales-plugin": "^1.1.5",
    "@react-spectrum/s2": "^1.2.0",
    "@tanstack/react-router": "^1.166.7",
    "graphql": "^16.13.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "unplugin-parcel-macros": "^0.2.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@storybook/addon-a11y": "^10.2.17",
    "@storybook/addon-docs": "^10.2.17",
    "@storybook/addon-vitest": "^10.2.17",
    "@storybook/react-vite": "^10.2.17",
    "@tanstack/router-cli": "^1.166.7",
    "@tanstack/router-plugin": "^1.166.7",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "globals": "^17.4.0",
    "lightningcss": "^1.32.0",
    "playwright": "^1.58.2",
    "storybook": "^10.2.17",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
