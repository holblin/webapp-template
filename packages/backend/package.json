{
  "name": "webapp-template-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "author": "Jean-Philippe Zolesio",
  "engines": {
    "node": ">=24.11.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:e2e": "tsx src/index.ts",
    "dev:dist": "tsc --watch --preserveWatchOutput & until [ -f dist/index.js ]; do sleep 1; done; node --watch dist/index.js",
    "compile": "tsc",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:unit:watch": "vitest --config vitest.config.ts",
    "test:unit:coverage": "vitest run --config vitest.config.ts --coverage",
    "start": "npm run compile && node ./dist/index.js"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@as-integrations/express5": "^1.1.2",
    "cors": "^2.8.6",
    "dataloader": "^2.2.3",
    "express": "^5.2.1",
    "graphql": "^16.13.1",
    "graphql-scalars": "^1.25.0",
    "lru-cache": "^11.2.7",
    "search-string": "^4.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
